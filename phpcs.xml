<?xml version="1.0"?>
<ruleset name="QuickPOS Coding Standard">
    <description>QuickPOS basic PHP quality checks</description>

    <rule ref="Generic.PHP.Syntax"/>
    <rule ref="Generic.Files.EndFileNewline"/>
    <rule ref="Generic.Files.LineEndings">
        <properties>
            <property name="eolChar" value="\r\n"/>
        </properties>
    </rule>

    <file>src</file>
    <file>tests</file>
</ruleset>